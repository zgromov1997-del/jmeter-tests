          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="JSR223 Sampler" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">def rnd = new Random()

vars.put(&quot;userId&quot;, java.util.UUID.randomUUID().toString())
vars.put(&quot;email&quot;, UUID.randomUUID().toString().substring(0, 8) + &quot;@test.com&quot;)

vars.put(&quot;streetAddress&quot;, &quot;1600 Amphitheatre Parkway&quot;)
vars.put(&quot;state&quot;, &quot;CA&quot;)
vars.put(&quot;country&quot;, &quot;United States&quot;)
vars.put(&quot;city&quot;, &quot;Mountain View&quot;)

vars.put(&quot;zipCode&quot;, String.valueOf(10000 + rnd.nextInt(90000)))
vars.put(&quot;userCurrency&quot;, &quot;RUB&quot;)

vars.put(&quot;creditCardCvv&quot;, String.valueOf(100 + rnd.nextInt(900)))
vars.put(&quot;creditCardExpirationMonth&quot;, String.valueOf(1 + rnd.nextInt(12)))
vars.put(&quot;creditCardExpirationYear&quot;, String.valueOf(2026 + rnd.nextInt(20)))

vars.put(&quot;creditCardNumber&quot;, &quot;4432-8015-6152-0454&quot;)</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
